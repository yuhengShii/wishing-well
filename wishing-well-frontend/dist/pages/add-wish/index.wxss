.page{background:#f5f5f5;min-height:100vh;padding:24rpx 16rpx}.header{align-items:center;display:flex;justify-content:space-between;margin-bottom:24rpx}.header .title{color:#333;font-size:24rpx;font-weight:700}.header .header-right .lang-btn{border:1rpx solid #4a90e2;border-radius:14rpx;color:#4a90e2;font-size:14rpx;padding:4rpx 12rpx}.form{background:#fff;border-radius:12rpx;padding:16rpx}.form .input{border:1rpx solid #eee;border-radius:8rpx;box-sizing:border-box;font-size:15rpx;margin-bottom:10rpx;padding:10rpx 12rpx;width:100%}.form .textarea{border:1rpx solid #eee;border-radius:8rpx;box-sizing:border-box;font-size:15rpx;height:120rpx;margin-bottom:10rpx;padding:10rpx 12rpx;resize:none;width:100%}.form .row{display:flex;gap:10rpx;margin-bottom:10rpx}.form .row .picker{background:#fff;border:1rpx solid #eee;border-radius:8rpx;flex:1;font-size:15rpx;padding:10rpx 12rpx}.form .row .picker .picker-text{color:#999}.form .row .input-small{border:1rpx solid #eee;border-radius:8rpx;flex:1;font-size:15rpx;padding:10rpx 12rpx}.form .btn-primary{background:#4a90e2;border:none;border-radius:8rpx;color:#fff;font-size:16rpx;margin-bottom:10rpx;padding:12rpx;width:100%}.form .btn-secondary{background:#fff;border:1rpx solid #ddd;border-radius:8rpx;color:#666;font-size:16rpx;padding:12rpx;width:100%}