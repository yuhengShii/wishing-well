.page{background:#f5f5f5;min-height:100vh;padding:24rpx 16rpx}.header{margin-bottom:24rpx}.header .title{color:#333;font-size:24rpx;font-weight:700}.list .empty{color:#999;padding:40rpx 0;text-align:center}.card{background:#fff;border-radius:10rpx;margin-bottom:10rpx;padding:14rpx}.card .card-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:6rpx}.card .card-header .card-title{color:#333;font-size:16rpx;font-weight:600}.card .card-header .card-status{border-radius:10rpx;font-size:12rpx;padding:2rpx 8rpx}.card .card-header .card-status.status-pending{background:#fff3e0;color:#e67e22}.card .card-header .card-status.status-approved{background:#e8f5e9;color:#27ae60}.card .card-header .card-status.status-implemented{background:#e3f2fd;color:#2980b9}.card .card-header .card-status.status-rejected{background:#fce4ec;color:#c0392b}.card .card-desc{color:#666;display:block;font-size:14rpx;margin-bottom:8rpx}.card .card-footer{align-items:center;display:flex;justify-content:space-between;margin-bottom:8rpx}.card .card-footer .tag{background:#f0f4ff;border-radius:6rpx;color:#4a90e2;font-size:12rpx;padding:2rpx 8rpx}.card .card-footer .card-time{color:#bbb;font-size:12rpx}.card .vote-bar{border-top:1rpx solid #f0f0f0;padding-top:8rpx}.card .vote-bar .voted-badge{color:#c0392b;font-size:14rpx}