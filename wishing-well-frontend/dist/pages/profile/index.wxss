.page{background:#f5f5f5;min-height:100vh;padding:24rpx 16rpx}.header{margin-bottom:24rpx}.header .title{color:#333;font-size:24rpx;font-weight:700}.user-card{align-items:center;background:#fff;border-radius:12rpx;display:flex;margin-bottom:16rpx;padding:20rpx}.user-card .avatar{align-items:center;background:#4a90e2;border-radius:30rpx;display:flex;height:60rpx;justify-content:center;margin-right:16rpx;width:60rpx}.user-card .avatar .avatar-text{color:#fff;font-size:24rpx}.user-card .user-info{flex:1}.user-card .user-info .nickname{color:#333;display:block;font-size:18rpx;font-weight:600;margin-bottom:4rpx}.user-card .user-info .user-id{color:#999;font-size:12rpx}.stats{background:#fff;border-radius:12rpx;display:flex;margin-bottom:16rpx;padding:20rpx}.stats .stat-item{flex:1;text-align:center}.stats .stat-item .stat-value{color:#4a90e2;display:block;font-size:24rpx;font-weight:700;margin-bottom:4rpx}.stats .stat-item .stat-label{color:#999;font-size:12rpx}.settings{background:#fff;border-radius:12rpx;overflow:hidden}.settings .setting-item{align-items:center;border-bottom:1rpx solid #f0f0f0;display:flex;justify-content:space-between;padding:16rpx}.settings .setting-item:last-child{border-bottom:none}.settings .setting-item .setting-label{color:#333;font-size:16rpx}.settings .setting-item .setting-value{color:#999;font-size:14rpx}