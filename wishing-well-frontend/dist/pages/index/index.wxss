.page{background:#f5f5f5;min-height:100vh;padding:24rpx 16rpx}.lang-btn-fixed{border:1rpx solid #4a90e2;border-radius:14rpx;color:#4a90e2;font-size:13rpx;padding:6rpx 14rpx;position:fixed;right:16rpx;top:24rpx;z-index:100}.fab{align-items:center;background:#4a90e2;border-radius:27rpx;bottom:80rpx;box-shadow:0 4rpx 12rpx rgba(74,144,226,.4);display:flex;height:54rpx;justify-content:center;position:fixed;right:20rpx;width:54rpx}.fab .fab-text{color:#fff;font-size:30rpx;font-weight:300}.sort-bar{align-items:center;display:flex;margin-bottom:16rpx}.sort-bar .sort-label{color:#555;font-size:16rpx;margin-right:10rpx}.sort-bar .sort-tabs{display:flex;gap:10rpx}.sort-bar .sort-tab{background:#e8e8e8;border-radius:16rpx;color:#888;font-size:14rpx;padding:6rpx 16rpx}.sort-bar .sort-tab.active{background:#4a90e2;color:#fff}.list .list-title{color:#333;display:block;font-size:22rpx;font-weight:700;margin-bottom:16rpx}.list .empty{color:#999;font-size:17rpx;padding:80rpx 0;text-align:center}.card{background:#fff;border-radius:12rpx;margin-bottom:14rpx;padding:18rpx}.card .card-header{align-items:center;display:flex;justify-content:space-between;margin-bottom:10rpx}.card .card-header .card-title{color:#333;font-size:18rpx;font-weight:600}.card .card-header .card-status{border-radius:10rpx;font-size:12rpx;padding:3rpx 10rpx}.card .card-header .card-status.status-pending{background:#fff3e0;color:#e67e22}.card .card-header .card-status.status-approved{background:#e8f5e9;color:#27ae60}.card .card-header .card-status.status-implemented{background:#e3f2fd;color:#2980b9}.card .card-header .card-status.status-rejected{background:#fce4ec;color:#c0392b}.card .card-desc{color:#555;display:block;font-size:16rpx;line-height:1.5;margin-bottom:12rpx}.card .card-footer{align-items:center;display:flex;justify-content:space-between;margin-bottom:10rpx}.card .card-footer .tag{background:#f0f4ff;border-radius:12rpx;color:#4a90e2;font-size:13rpx;padding:3rpx 12rpx}.card .card-footer .card-time{color:#999;font-size:13rpx}.card .vote-bar{align-items:center;border-top:1rpx solid #f0f0f0;display:flex;gap:10rpx;padding-top:12rpx}.card .vote-bar .vote-btn{background:#fff3f3;border:1rpx solid #fdd;border-radius:18rpx;color:#e74c3c;font-size:15rpx;line-height:1.5;padding:6rpx 16rpx}.card .vote-bar .vote-btn.voted{background:#fdeaea;color:#c0392b}.card .vote-bar .vote-hint{color:#aaa;font-size:13rpx}